# Lamplight configuration — copy to .env and adjust. Nothing is hardcoded;
# docker-compose reads every value from here (with the defaults shown).
#
#   cp .env.example .env
#   docker compose up --build -d

# --- image / build ---
# Node base image tag used to build and run the container.
NODE_VERSION=20-alpine
# Tag applied to the built image, and the container name.
IMAGE_TAG=latest
CONTAINER_NAME=bookclub

# --- runtime ---
# Display name of the club (on the cover and the running head).
CLUB_NAME=The Smallest Book Club Who Ever Lived
NODE_ENV=production
# Port the server listens on INSIDE the container.
PORT=8787
# Port published on the host: browse to http://localhost:${HOST_PORT}
HOST_PORT=8787
# Where the SQLite database file lives inside the container (on the volume).
DB_PATH=/data/bookclub.db

# Send the session cookie with the Secure flag.
#   false -> served over plain HTTP (reached by IP/LAN, no TLS)  [default]
#   true  -> behind an HTTPS reverse proxy
COOKIE_SECURE=false

# --- storage ---
# Leave unset to use the managed Docker volume "bookclub-data".
# Or set an absolute host path to bind-mount instead:
# DATA_PATH=/srv/bookclub/data
